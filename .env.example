OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-2
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Optional but strongly recommended. If set, clients must send:
# Authorization: Bearer <APP_API_KEY>
APP_API_KEY=replace-with-a-long-random-secret

# Comma-separated origins. Use * only for temporary development.
ALLOWED_ORIGINS=http://localhost:8081,https://your-app.example
